{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "browser": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "@browsermcp/mcp@latest"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest"]
    },
    "mermaid-charts": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.mermaid.ai/mcp"
    }
  }
}
