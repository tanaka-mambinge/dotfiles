{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "browser": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "@browsermcp/mcp@latest"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest"]
    },
    "mermaid-charts": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.mermaid.ai/mcp"
    },
    "mobile-mcp": {
      "type": "local",
      "command": ["npx", "@mobilenext/mobile-mcp@latest"],
      "enabled": false
    },
    "pencil": {
      "command": [
        "/tmp/.mount_PencilSpAxWQ/resources/app.asar.unpacked/out/mcp-server-linux-x64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "npm run *": "allow",
      "fastapi *": "allow"
    }
  },
  "agent": {
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    },
    "general": {
      "model": "github-copilot/gpt-5-mini"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "small_model": "github-copilot/gpt-5-mini",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true
  }
}
