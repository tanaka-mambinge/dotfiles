{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "browser": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "@browsermcp/mcp@latest"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest"]
    },
    "mermaid-charts": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.mermaid.ai/mcp"
    },
    "mobile-mcp": {
      "type": "local",
      "command": ["npx", "@mobilenext/mobile-mcp@latest"],
      "enabled": false
    },
    "android-mcp": {
      "type": "local",
      "command": ["/home/t12e/.local/bin/uvx", "android-mcp"],
      "enabled": false
    }
  },
  "permission": {
    "bash": {
      "npm *": "deny",
      "fastapi *": "deny",
      "pip *": "deny"
    }
  },
  "agent": {
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    },
    "general": {
      "model": "github-copilot/gpt-5-mini"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  }
}
