{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "pencil": {
      "command": [
        "/tmp/.mount_Pencildgmx3P/resources/app.asar.unpacked/out/mcp-server-linux-x64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "npm run *": "allow",
      "fastapi *": "allow"
    },
    "external_directory": {
      "/tmp/**": "allow",
      "~/Code/**": "allow",
      "~/Downloads/**": "allow",
      "~/Documents/**": "allow",
      "~/.dotfiles/ai-configs/skills/**": "allow",
      "~/.cache/": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true
  },
  "plugin": ["@warp-dot-dev/opencode-warp@0.1.5"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3_4b_opencode": {
            "id": "qwen3:4b-opencode",
            "name": "Qwen 3 4B OpenCode",
            "tools": true
        },
        "qwen3_4b": {
            "id": "qwen3:4b",
            "name": "Qwen 3 4B",
            "tools": true
        },
        "qwen35_4b": {
            "id": "qwen3.5:4b",
            "name": "Qwen 3.5 4B",
            "tools": true
        },
        "qwen3_4b_instruct": {
            "id": "qwen3:4b-instruct",
            "name": "Qwen 3 4B Instruct",
            "tools": true
        }
      }
    }
  }
}
