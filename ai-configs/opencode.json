{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest"],
      "enabled": false
    },
    "dart-mcp-server": {
      "type": "local",
      "command": ["dart", "mcp-server"],
      "enabled": false,
      "environment": {}
    },
    "pencil": {
      "command": [
        "/tmp/.mount_Penciljo5Jy0/resources/app.asar.unpacked/out/mcp-server-linux-x64",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "bash": {
      "npm run *": "allow",
      "fastapi *": "allow"
    },
    "external_directory": {
      "/tmp/**": "allow",
      "~/Code/**": "allow"
    }
  },
  "agent": {
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    },
    "general": {
      "model": "github-copilot/gpt-5-mini"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "small_model": "github-copilot/gpt-5-mini",
  "compaction": {
    "auto": true,
    "prune": true
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true
  },
  "plugin": ["@warp-dot-dev/opencode-warp"]
}
